# ─────────────────────────────────────────────────────────────
# Community Clone — environment variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# --- Database ---
# Dev default uses SQLite so you don't need Postgres locally for M1.
# Swap to Neon/Postgres at M4+ when we add array columns / FTS.
DATABASE_URL="file:./dev.db"
# Production example: DATABASE_URL="postgresql://USER:PASS@HOST/db?sslmode=require"

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# --- Google OAuth (optional in dev; required for "Sign in with Google") ---
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email (Resend) ---
# https://resend.com/api-keys
# In dev, if unset, magic-link URLs are logged to the server console.
AUTH_RESEND_KEY=""
EMAIL_FROM="Community Clone <onboarding@resend.dev>"

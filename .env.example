# ─────────────────────────────────────────────────────────────
# Community Clone — environment variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# --- Database ---
# Dev default uses SQLite so you don't need Postgres locally for M1.
# Swap to Neon/Postgres at M4+ when we add array columns / FTS.
DATABASE_URL="file:./dev.db"
# Production example: DATABASE_URL="postgresql://USER:PASS@HOST/db?sslmode=require"

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# --- Google OAuth (optional in dev; required for "Sign in with Google") ---
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email (Resend) ---
# https://resend.com/api-keys
# In dev, if unset, magic-link URLs are logged to the server console.
AUTH_RESEND_KEY=""
EMAIL_FROM="Community Clone <onboarding@resend.dev>"

# --- Vercel Blob (comment voice notes) ---
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=""

# --- Google Calendar / Meet booking (M11) ---
# Separate OAuth client from AUTH_GOOGLE_* — this one has calendar + meet scopes.
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URL="http://localhost:3000/api/google/callback"
# 32-byte base64 used to AES-GCM encrypt Google refresh_token at rest.
# Generate with: openssl rand -base64 32
# In dev, if unset, we derive a key from AUTH_SECRET (a warning is logged).
TOKEN_ENCRYPTION_KEY=""

# --- Cron (M10 event reminders) ---
# Required only for non-Vercel curl hits to /api/cron/event-reminders.
# On Vercel, the x-vercel-cron header auth is automatic.
CRON_SECRET=""

# --- Pusher real-time (M15) ---
# https://dashboard.pusher.com/ — create a Channels app, copy credentials.
# App falls back to polling when these are absent (graceful degradation).
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=
# Client-side key: same value as PUSHER_APP_KEY but exposed to the browser.
NEXT_PUBLIC_PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_APP_CLUSTER=

# --- Stripe paid courses (M16) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Publishable key (safe to expose to browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- App base URL ---
# Used for Stripe success/cancel redirect URLs. Auto-detected on Vercel via VERCEL_URL.
NEXT_PUBLIC_APP_URL=

# --- SaaS: Nadi multi-tenant platform ---
# Platform root domain (no www prefix). Subdomains are routed as tenant workspaces.
NEXT_PUBLIC_APP_DOMAIN=nadi.app

# AES-256-GCM key for encrypting PaymentMethod credentials at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Super-admin access (comma-separated email list OR a specific user ID).
# Users with these emails get access to /super-admin.
SUPER_ADMIN_EMAILS=
SUPER_ADMIN_ID=

# --- Nadi's own Stripe billing (for tenant plan subscriptions) ---
# Separate from the per-group Stripe used by tenants for member subscriptions.
NADI_STRIPE_SECRET_KEY=
NADI_STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_NADI_STRIPE_PUBLISHABLE_KEY=
